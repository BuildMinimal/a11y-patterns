{
  "_pattern": "06-keyboard-navigation/combobox-autocomplete",
  "_description": "Design tokens for the combobox-autocomplete pattern. Colors used in after/styles.css.",

  "color": {
    "input": {
      "border-default": {
        "value": "#d1d5db",
        "usage": "Combobox input border at rest"
      },
      "border-focus": {
        "value": "#2563eb",
        "contrast-on-white": "6.70:1",
        "wcag": "AA",
        "usage": "Combobox input border when focused"
      },
      "focus-ring": {
        "value": "rgba(37,99,235,0.15)",
        "usage": "Semi-transparent focus ring shadow around the focused input"
      },
      "text": {
        "value": "#1a1a1a",
        "contrast-on-white": "18.1:1",
        "wcag": "AAA",
        "usage": "Input text color"
      }
    },
    "listbox": {
      "background": {
        "value": "#ffffff",
        "usage": "Popup listbox background"
      },
      "border": {
        "value": "#e5e7eb",
        "usage": "Popup listbox border"
      }
    },
    "option": {
      "text": {
        "value": "#374151",
        "contrast-on-white": "9.73:1",
        "wcag": "AAA",
        "usage": "Default option text"
      },
      "background-hover": {
        "value": "#f3f4f6",
        "usage": "Option background on mouse hover"
      },
      "background-active": {
        "value": "#eff6ff",
        "usage": "Option background when keyboard-active (aria-activedescendant target)"
      },
      "text-active": {
        "value": "#1e40af",
        "contrast-on-active-bg": "7.45:1",
        "wcag": "AAA",
        "usage": "Option text when keyboard-active"
      },
      "background-selected": {
        "value": "#dbeafe",
        "usage": "Option background for the previously confirmed selection (aria-selected=true)"
      },
      "text-selected": {
        "value": "#1d4ed8",
        "contrast-on-selected-bg": "6.06:1",
        "wcag": "AA",
        "usage": "Option text for the previously confirmed selection"
      }
    }
  }
}
