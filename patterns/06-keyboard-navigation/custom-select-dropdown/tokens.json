{
  "_pattern": "06-keyboard-navigation/custom-select-dropdown",
  "_description": "Design tokens for the custom-select-dropdown pattern. Colors used in after/styles.css.",

  "color": {
    "trigger": {
      "border-default": {
        "value": "#d1d5db",
        "usage": "Trigger button border (closed state)"
      },
      "border-open": {
        "value": "#2563eb",
        "contrast-on-white": "6.70:1",
        "wcag": "AA",
        "usage": "Trigger button border when dropdown is open — matches listbox border for visual continuity"
      },
      "background": {
        "value": "#ffffff",
        "usage": "Trigger button background"
      },
      "text": {
        "value": "#1a1a1a",
        "contrast-on-white": "18.1:1",
        "wcag": "AAA",
        "usage": "Trigger button label text"
      }
    },
    "focus": {
      "ring": {
        "value": "#2563eb",
        "contrast-on-white": "6.70:1",
        "wcag": "AA",
        "usage": "Focus outline on trigger button and active option — 2px solid, 2px offset"
      }
    },
    "listbox": {
      "background": {
        "value": "#ffffff",
        "usage": "Dropdown menu background"
      },
      "border": {
        "value": "#2563eb",
        "usage": "Dropdown menu border"
      }
    },
    "option": {
      "text": {
        "value": "#1a1a1a",
        "contrast-on-white": "18.1:1",
        "wcag": "AAA",
        "usage": "Default option text"
      },
      "hover-background": {
        "value": "#f3f4f6",
        "usage": "Option background on mouse hover"
      },
      "selected-background": {
        "value": "#dbeafe",
        "usage": "Background of the currently selected option"
      },
      "selected-text": {
        "value": "#1e40af",
        "contrast-on-selected-bg": "7.16:1",
        "wcag": "AAA",
        "usage": "Text of the currently selected option on #dbeafe background"
      },
      "active-background": {
        "value": "#eff6ff",
        "usage": "Background of the keyboard-highlighted option (aria-activedescendant)"
      }
    }
  }
}
