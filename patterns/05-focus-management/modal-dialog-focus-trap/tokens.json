{
  "_pattern": "05-focus-management/modal-dialog-focus-trap",
  "_description": "Design tokens for the modal-dialog-focus-trap pattern. All values are used in after/styles.css.",

  "color": {
    "modal": {
      "overlay": {
        "value": "rgba(0, 0, 0, 0.5)",
        "usage": "Modal backdrop background",
        "note": "Semi-transparent black overlay behind the modal"
      },
      "background": {
        "value": "#ffffff",
        "usage": "Modal container background",
        "note": "White background for the modal content"
      },
      "text": {
        "value": "#1a1a1a",
        "contrast-on-white": "18.1:1",
        "wcag": "AAA",
        "usage": "Modal heading and body text",
        "note": "Near-black for maximum contrast"
      },
      "border": {
        "value": "#e5e7eb",
        "usage": "Modal border color (if used)",
        "note": "Light gray border for subtle definition"
      }
    },
    "text": {
      "secondary": {
        "value": "#4a5568",
        "contrast-on-white": "5.74:1",
        "wcag": "AA",
        "usage": "Modal description and supporting text",
        "note": "Medium gray for secondary text"
      }
    },
    "interactive": {
      "primary-background": {
        "value": "#1d4ed8",
        "usage": "Primary button background",
        "note": "Blue for primary actions"
      },
      "primary-text": {
        "value": "#ffffff",
        "contrast-on-primary-bg": "7.22:1",
        "wcag": "AAA",
        "usage": "White text on primary button",
        "note": "White on blue passes AAA"
      },
      "secondary-background": {
        "value": "#f3f4f6",
        "usage": "Secondary button background",
        "note": "Light gray for secondary actions"
      },
      "secondary-text": {
        "value": "#1a1a1a",
        "contrast-on-secondary-bg": "15.3:1",
        "wcag": "AAA",
        "usage": "Dark text on secondary button",
        "note": "Near-black on light gray passes AAA"
      },
      "danger-background": {
        "value": "#dc2626",
        "usage": "Danger button background",
        "note": "Red for destructive actions"
      },
      "danger-text": {
        "value": "#ffffff",
        "contrast-on-danger-bg": "5.52:1",
        "wcag": "AA",
        "usage": "White text on danger button",
        "note": "White on red passes AA"
      }
    },
    "focus": {
      "ring": {
        "value": "#1d4ed8",
        "contrast-on-white": "7.22:1",
        "wcag": "AA",
        "usage": "Focus ring outline color — 2px solid, 2px offset",
        "note": "Meets WCAG 2.4.11 (3:1 minimum for focus indicators)"
      }
    }
  },

  "spacing": {
    "modal": {
      "padding": {
        "value": "1.5rem",
        "usage": "Modal content padding",
        "note": "Generous padding for comfortable reading"
      },
      "max-width": {
        "value": "500px",
        "usage": "Modal maximum width",
        "note": "Optimal width for readability"
      }
    },
    "button": {
      "padding-x": {
        "value": "1.25rem",
        "usage": "Button horizontal padding",
        "note": "Comfortable touch target size"
      },
      "padding-y": {
        "value": "0.625rem",
        "usage": "Button vertical padding",
        "note": "Comfortable touch target size"
      }
    }
  },

  "typography": {
    "modal": {
      "title": {
        "font-size": "1.25rem",
        "font-weight": "600",
        "usage": "Modal heading",
        "note": "Clear hierarchy for modal title"
      },
      "description": {
        "font-size": "1rem",
        "line-height": "1.6",
        "usage": "Modal description text",
        "note": "Readable line length and spacing"
      }
    }
  },

  "z-index": {
    "modal": {
      "value": "1000",
      "usage": "Modal z-index",
      "note": "Ensures modal appears above all other content"
    }
  }
}
