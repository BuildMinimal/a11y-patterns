{
  "_pattern": "01-color-contrast/focus-indicator-contrast",
  "_description": "Design tokens for focus-indicator-contrast pattern. All values are used in after/styles.css. Contrast ratios are calculated against #ffffff (page background) unless noted.",

  "color": {
    "background": {
      "page": {
        "value": "#f8fafc",
        "usage": "Page background color"
      },
      "card": {
        "value": "#ffffff",
        "usage": "Card background color"
      }
    },
    "text": {
      "primary": {
        "value": "#1a1a1a",
        "contrast-on-white": "18.1:1",
        "wcag": "AAA",
        "usage": "Headings, primary text",
        "note": "Near-black. Maximizes contrast without harshness."
      },
      "secondary": {
        "value": "#4a5568",
        "contrast-on-white": "5.74:1",
        "wcag": "AA",
        "usage": "Descriptions, supporting text",
        "note": "Creates visual hierarchy below primary."
      },
      "label": {
        "value": "#374151",
        "contrast-on-white": "8.59:1",
        "wcag": "AAA",
        "usage": "Form labels",
        "note": "Dark gray for clear label visibility."
      }
    },
    "border": {
      "input": {
        "value": "#d1d5db",
        "usage": "Input field borders"
      },
      "card": {
        "value": "#e5e7eb",
        "usage": "Card borders"
      }
    },
    "focus": {
      "ring": {
        "value": "#1d4ed8",
        "contrast-on-white": "6.70:1",
        "wcag": "AA",
        "usage": "Focus ring/outline color for all interactive elements",
        "note": "Brand blue provides excellent contrast. Meets WCAG 2.4.11 (3:1 minimum for focus indicators)."
      },
      "fail-example": {
        "value": "#d1d5db",
        "contrast-on-white": "1.51:1",
        "wcag": "FAIL",
        "usage": "Shown in before/ — do not use for focus indicators",
        "note": "Light blue-gray looks 'subtle' but fails 3:1 requirement dramatically."
      }
    },
    "interactive": {
      "primary": {
        "value": "#1d4ed8",
        "usage": "Primary button background"
      },
      "primary-text": {
        "value": "#ffffff",
        "contrast-on-primary-bg": "6.70:1",
        "usage": "White text on primary button (#1d4ed8 background)",
        "note": "White on #1d4ed8 = 6.70:1 (AA). No wcag field — validator checks against white (1:1); this token is only meaningful against its button background."
      },
      "secondary": {
        "value": "#1d4ed8",
        "usage": "Secondary button text and border"
      }
    },
    "link": {
      "default": {
        "value": "#1d4ed8",
        "contrast-on-white": "6.70:1",
        "wcag": "AA",
        "usage": "Link text color"
      }
    }
  },

  "spacing": {
    "card-padding": {
      "value": "2rem",
      "usage": "Padding inside cards"
    },
    "field-gap": {
      "value": "1.25rem",
      "usage": "Gap between form fields"
    },
    "button-padding": {
      "value": "0.75rem 1.5rem",
      "usage": "Button padding"
    },
    "link-gap": {
      "value": "1.5rem",
      "usage": "Gap between links"
    }
  },

  "typography": {
    "title": {
      "value": "1.25rem",
      "weight": "700",
      "usage": "Card title"
    },
    "description": {
      "value": "0.9375rem",
      "usage": "Card description text"
    },
    "label": {
      "value": "0.875rem",
      "weight": "500",
      "usage": "Form labels"
    },
    "input": {
      "value": "0.9375rem",
      "usage": "Input text size"
    },
    "button": {
      "value": "0.9375rem",
      "weight": "600",
      "usage": "Button text"
    },
    "link": {
      "value": "0.9375rem",
      "usage": "Link text"
    }
  },

  "focus": {
    "ring-width": {
      "value": "2px",
      "usage": "Width of focus ring"
    },
    "ring-offset": {
      "value": "2px",
      "usage": "Offset of focus ring from element (0 for inputs, 2px for others)"
    }
  }
