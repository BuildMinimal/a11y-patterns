{
  "_description": "Global accessible color palette. All contrast ratios are calculated against #ffffff (white) unless noted. Values verified against WCAG 2.1 luminance formula.",

  "color": {
    "neutral": {
      "50":  { "value": "#f9fafb", "note": "Page background — not for text" },
      "100": { "value": "#f3f4f6", "note": "Subtle surface — not for text" },
      "200": { "value": "#e5e7eb", "note": "Borders and dividers" },
      "300": { "value": "#d1d5db", "note": "Disabled borders" },
      "400": { "value": "#9ca3af", "contrast-on-white": "2.54:1", "wcag": "FAIL", "note": "Too light for text — for decorative use only" },
      "500": { "value": "#6b7280", "contrast-on-white": "4.63:1", "wcag": "AA",   "note": "Minimum passing gray for normal text on white" },
      "600": { "value": "#4b5563", "contrast-on-white": "6.81:1", "wcag": "AA",   "note": "Secondary text" },
      "700": { "value": "#374151", "contrast-on-white": "9.54:1", "wcag": "AAA",  "note": "Strong secondary text" },
      "800": { "value": "#1f2937", "contrast-on-white": "14.0:1", "wcag": "AAA",  "note": "Primary text (dark)" },
      "900": { "value": "#111827", "contrast-on-white": "17.7:1", "wcag": "AAA",  "note": "High-emphasis text" },
      "950": { "value": "#0a0f1a", "contrast-on-white": "19.4:1", "wcag": "AAA",  "note": "Maximum contrast" }
    },

    "text": {
      "primary":   { "value": "#1a1a1a", "contrast-on-white": "18.1:1", "wcag": "AAA", "note": "Body text, headings" },
      "secondary": { "value": "#4a5568", "contrast-on-white": "5.74:1", "wcag": "AA",  "note": "Supporting text, captions" },
      "muted":     { "value": "#6b7280", "contrast-on-white": "4.82:1", "wcag": "AA",  "note": "Minimum passing gray for normal text on white — do not go lighter" },
      "disabled":  { "value": "#a0aec0", "contrast-on-white": "2.86:1", "wcag": "FAIL","note": "Disabled state — do not use for interactive or informative text" },
      "inverse":   { "value": "#ffffff", "contrast-on-black": "21:1",   "note": "White text on dark backgrounds — no wcag field, validator checks against white" },
      "link":      { "value": "#1d4ed8", "contrast-on-white": "6.70:1", "wcag": "AA",  "note": "Interactive link color — meets AA. Use #1e3a8a for AAA contexts." },
      "link-hover":{ "value": "#1e3a8a", "contrast-on-white": "11.0:1", "wcag": "AAA", "note": "Link hover/focus state" },
      "danger":    { "value": "#b91c1c", "contrast-on-white": "5.91:1", "wcag": "AA",  "note": "Error text — meets AA, never rely on color alone" },
      "success":   { "value": "#15803d", "contrast-on-white": "5.08:1", "wcag": "AA",  "note": "Success text — meets AA, never rely on color alone" },
      "warning":   { "value": "#92400e", "contrast-on-white": "7.49:1", "wcag": "AAA", "note": "Warning text on white — amber hues often fail, this one passes AAA" }
    },

    "surface": {
      "page":    { "value": "#ffffff", "note": "Default page background" },
      "subtle":  { "value": "#f9fafb", "note": "Slightly elevated surface (cards, sidebars)" },
      "raised":  { "value": "#f3f4f6", "note": "Raised surface (dropdowns, tooltips)" },
      "overlay": { "value": "#1f2937", "note": "Modal overlay backdrop" }
    },

    "border": {
      "default":  { "value": "#e5e7eb", "note": "Default border on white" },
      "strong":   { "value": "#9ca3af", "note": "More visible border" },
      "focus":    { "value": "#1d4ed8", "note": "Focus ring — meets 3:1 against white (WCAG 2.4.11)" }
    },

    "interactive": {
      "primary":        { "value": "#1d4ed8", "note": "Primary button background" },
      "primary-text":   { "value": "#ffffff", "contrast-on-primary": "6.70:1", "note": "White text on primary (#1d4ed8) background — no wcag field, measured against button not white" },
      "primary-hover":  { "value": "#1e3a8a", "contrast-on-white": "11.0:1", "wcag": "AAA", "note": "Primary button hover — also usable as link text for AAA" },
      "danger":         { "value": "#dc2626", "note": "Destructive action button background" },
      "danger-text":    { "value": "#ffffff", "contrast-on-danger": "4.67:1", "note": "White text on danger (#dc2626) background — no wcag field, measured against button not white" }
    },

    "fail-examples": {
      "_note": "These colors are included to document common failing values. Do not use them for text.",
      "gray-400-on-white": { "value": "#9ca3af", "contrast-on-white": "2.54:1", "wcag": "FAIL" },
      "light-blue-on-white": { "value": "#93c5fd", "contrast-on-white": "2.19:1", "wcag": "FAIL" },
      "light-green-on-white": { "value": "#86efac", "contrast-on-white": "1.56:1", "wcag": "FAIL" },
      "yellow-text-on-white": { "value": "#eab308", "contrast-on-white": "1.97:1", "wcag": "FAIL" }
    }
  }
}
